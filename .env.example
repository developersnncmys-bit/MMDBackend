PORT=9000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=Cluster0

# Deployed website URL (no trailing slash). Used as the redirect base after
# a successful or failed Paytm payment.
WEBSITE_URL=https://makemydocuments.com

# MSG91 OTP (send + verify proxied to /api/otp/*).
MSG91_OTP_URL=https://control.msg91.com/api/v5/otp
MSG91_VERIFY_OTP=https://control.msg91.com/api/v5/otp/verify
OTP_AUTH_KEY=<msg91-auth-key>
OTP_TEMPLATE_KEY=<msg91-otp-template-id>

# MSG91 transactional SMS (post-payment confirmation flow).
MSG91_AUTH_KEY=<msg91-auth-key>
MSG91_SENDER_ID=<6-char-sender>
MSG91_TEMPLATE_PAN=<flow-id-for-pan>
MSG91_TEMPLATE_SENIOR=<flow-id-for-senior-citizen>
MSG91_TEMPLATE_DEFAULT=<flow-id-for-everything-else>
MSG91_ROUTE=4

# SMTP for confirmation email.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=<account-email>
SMTP_PASS=<smtp-app-password>

# Paytm (use securegw-stage for testing, securegw for prod).
PAYTM_MID=<paytm-merchant-id>
PAYTM_MERCHANT_KEY=<paytm-merchant-key>
PAYTM_WEBSITE=DEFAULT
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CHANNEL_ID=WEB
PAYTM_CALLBACK_URL=https://<backend-host>/api/PG/paytm/callback
PAYTM_TRANSACTION_URL=https://securegw-stage.paytm.in/order/process

SESSION_SECRET=<random-long-hex>
